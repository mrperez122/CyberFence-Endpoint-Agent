{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CyberFence Endpoint",
  "version": "0.3.0",
  "identifier": "com.cyberfence.endpoint",
  "build": {
    "frontendDist": "ui/build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "id": "cf-tray",
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": false,
      "tooltip": "CyberFence Endpoint Protection"
    },
    "windows": [
      {
        "label": "main",
        "title": "CyberFence Endpoint Protection v0.3.0",
        "width": 1080,
        "height": 700,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "visible": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "url": "/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "shortDescription": "CyberFence Endpoint Protection \u2014 real-time malware scanning",
    "longDescription": "CyberFence Endpoint Protection Agent monitors your device in real-time, detecting and quarantining threats powered by the CyberFence Engine.",
    "copyright": "Copyright \u00a9 2026 Perez Technology Group, LLC",
    "category": "Security",
    "publisher": "Perez Technology Group, LLC",
    "homepage": "https://www.cyberfenceplatform.com",
    "resources": [],
    "externalBin": []
  }
}