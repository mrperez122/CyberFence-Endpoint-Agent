{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CyberFence Endpoint",
  "version": "0.1.0",
  "identifier": "com.cyberfence.endpoint",
  "build": {
    "frontendDist": "../build",
    "devUrl":       "http://localhost:1420",
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "id":       "cf-tray",
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "CyberFence Endpoint Protection"
    },
    "windows": [
      {
        "label":            "main",
        "title":            "CyberFence Endpoint",
        "width":            900,
        "height":           620,
        "minWidth":         800,
        "minHeight":        560,
        "resizable":        true,
        "visible":          false,
        "decorations":      true,
        "transparent":      false,
        "center":           true,
        "url":              "/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
