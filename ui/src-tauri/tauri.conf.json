{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CyberFence Endpoint",
  "version": "0.1.0",
  "identifier": "com.cyberfence.endpoint",

  "build": {
    "frontendDist":       "../build",
    "devUrl":             "http://localhost:1420",
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build"
  },

  "app": {
    "withGlobalTauri": true,

    "trayIcon": {
      "id":             "cf-tray",
      "iconPath":       "icons/tray-icon.png",
      "iconAsTemplate": false,
      "tooltip":        "CyberFence Endpoint Protection"
    },

    "windows": [
      {
        "label":        "main",
        "title":        "CyberFence Endpoint Protection",
        "width":        1000,
        "height":       660,
        "minWidth":     860,
        "minHeight":    580,
        "resizable":    true,
        "visible":      true,
        "decorations":  true,
        "transparent":  false,
        "center":       true,
        "url":          "/"
      }
    ],

    "security": {
      "csp": null
    }
  },

  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "shortDescription": "CyberFence Endpoint Protection — real-time malware scanning",
    "longDescription":  "CyberFence Endpoint Protection Agent monitors your device in real-time, detecting and quarantining threats powered by the CyberFence Engine.",
    "copyright": "Copyright © 2026 Perez Technology Group, LLC",
    "category": "Security",
    "publisher": "Perez Technology Group, LLC",
    "homepage": "https://www.cyberfenceplatform.com",
    "resources": [],
    "externalBin": []
  }
}
