        <File Id="Clam_ClamAV_README_md" Name="ClamAV-README.md" Source="/home/user/workspace/cyberfence-endpoint-agent/dist/CyberFence-Endpoint-v0.1.0-Windows/engine/ClamAV-README.md" KeyPath="yes" />
      </Component>
      <Component Id="Comp_Clam_clamconf_exe" Guid="{C01C7713-FE92-5B1E-93B6-1E233FFC1F71}" Win64="yes">
