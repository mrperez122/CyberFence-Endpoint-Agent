<?xml version="1.0" encoding="UTF-8"?>
<!-- CyberFence Endpoint Protection Agent v0.1.0 -->
<!-- Product_wixl.wxs — Full production installer with CyberFence Engine + Dashboard UI -->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
    Id="{4066040C-E6D0-5245-BD98-4420FB83B3C7}"
    Name="CyberFence Endpoint Protection"
    Language="1033"
    Version="0.1.0.0"
    Manufacturer="Perez Technology Group, LLC"
    UpgradeCode="{61C3AB38-E735-5962-B342-EB616B1B2EE2}">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Description="CyberFence Endpoint Protection v0.1.0 — Real-time malware protection with CyberFence Engine"
      Manufacturer="Perez Technology Group, LLC" />

    <MediaTemplate EmbedCab="yes" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of CyberFence Endpoint Protection is already installed."
      AllowSameVersionUpgrades="no" />

    <!-- Directory tree -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="CompanyDir" Name="Perez Technology Group">
          <Directory Id="INSTALLDIR" Name="CyberFence Endpoint">
            <Directory Id="BinDir"    Name="bin" />
            <Directory Id="ConfigDir" Name="config" />
            <Directory Id="LogsDir"   Name="logs" />
            <Directory Id="ScriptsDir" Name="scripts" />
            <Directory Id="EngineDir"  Name="engine">
              <Directory Id="EngineConfExamplesDir" Name="conf_examples" />
              <Directory Id="EngineDbDir" Name="db" />
            </Directory>
            <!-- Dashboard UI -->
            <Directory Id="UiAppDir" Name="ui">
              <Directory Id="UiBuildDir" Name="build">
                <Directory Id="UiDir__app" Name="_app">
                  <Directory Id="UiDir__app_immutable" Name="immutable">
                    <Directory Id="UiDir__app_immutable_assets" Name="assets" />
                    <Directory Id="UiDir__app_immutable_chunks" Name="chunks" />
                    <Directory Id="UiDir__app_immutable_entry" Name="entry" />
                    <Directory Id="UiDir__app_immutable_nodes" Name="nodes" />
                  </Directory>
                </Directory>
                <Directory Id="UiDir_assets" Name="assets" />
              </Directory>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="CyberFence" />
      </Directory>
      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>

    <!-- Agent binary + service -->
    <DirectoryRef Id="BinDir">
      <Component Id="CompAgent" Guid="{B57ABAD3-9323-5AC0-9F92-95819DCF5043}" Win64="yes">
        <File Id="CfAgentExe" Name="cf-agent.exe" Source="DIST_DIR_PLACEHOLDER/cf-agent.exe" KeyPath="yes" />
        <ServiceInstall Id="CyberFenceService" Name="CyberFenceAgent"
          DisplayName="CyberFence Endpoint Protection Agent"
          Description="Real-time file monitoring and malware scanning."
          Type="ownProcess" Start="auto" ErrorControl="normal" Account="LocalSystem" />
        <ServiceControl Id="SvcControl" Name="CyberFenceAgent"
          Start="install" Stop="both" Remove="uninstall" Wait="yes" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\Perez Technology Group\CyberFence Endpoint" Name="InstallDir" Type="string" Value="[INSTALLDIR]" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\Perez Technology Group\CyberFence Endpoint" Name="Version" Type="string" Value="0.1.0" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\Perez Technology Group\CyberFence Endpoint" Name="EngineVersion" Type="string" Value="ClamAV 1.4.4 LTS" />
      </Component>
    </DirectoryRef>

    <!-- Dashboard UI (Tauri/WebView2 app) -->
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="CompUI" Guid="{A1B2C3D4-0001-4000-9000-AABB00000001}" Win64="yes">
        <File Id="CyberFenceExe" Name="CyberFence.exe" Source="DIST_DIR_PLACEHOLDER/CyberFence.exe" KeyPath="yes" />
      </Component>
      <Component Id="CompReadme" Guid="{78A183AD-F6DA-569A-9D1D-B18D74A59AE4}" Win64="yes">
        <File Id="ReadmeTxt" Name="README.txt" Source="DIST_DIR_PLACEHOLDER/README.txt" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="ConfigDir">
      <Component Id="CompConfig" Guid="{393BBA5E-A34A-51A6-BFAB-9441BAD6B4D2}" Win64="yes">
        <File Id="ConfigToml" Name="config.toml" Source="DIST_DIR_PLACEHOLDER/config.toml" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="ScriptsDir">
      <Component Id="CompInstallBat" Guid="{8C57A414-5AE7-561B-A6D8-45A04180D84D}" Win64="yes">
        <File Id="InstallBat" Name="install.bat" Source="DIST_DIR_PLACEHOLDER/install.bat" KeyPath="yes" />
      </Component>
      <Component Id="CompUninstallBat" Guid="{AC7947ED-7E34-53E0-9D2D-C9A86CEE9221}" Win64="yes">
        <File Id="UninstallBat" Name="uninstall.bat" Source="DIST_DIR_PLACEHOLDER/uninstall.bat" KeyPath="yes" />
      </Component>
      <Component Id="CompTestEicar" Guid="{583E6901-EC51-50DF-AFFC-05A4082C378D}" Win64="yes">
        <File Id="TestEicarBat" Name="test-eicar.bat" Source="DIST_DIR_PLACEHOLDER/test-eicar.bat" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Start Menu shortcuts -->
    <DirectoryRef Id="AppMenuFolder">
      <Component Id="CompStartMenu" Guid="{BFFB7AF4-F405-53E6-860C-00A782728082}">
        <Shortcut Id="StartMenuApp" Name="CyberFence Endpoint Protection"
          Description="Open the CyberFence Endpoint Protection dashboard"
          Target="[INSTALLDIR]CyberFence.exe" WorkingDirectory="INSTALLDIR" />
        <Shortcut Id="StartMenuUninstall" Name="Uninstall CyberFence Endpoint"
          Target="[SystemFolder]msiexec.exe"
          Arguments="/x {4066040C-E6D0-5245-BD98-4420FB83B3C7}" />
        <RemoveFolder Id="CleanStartMenu" Directory="AppMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="SOFTWARE\Perez Technology Group\CyberFence Endpoint"
          Name="StartMenuInstalled" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Desktop shortcut -->
    <DirectoryRef Id="DesktopFolder">
      <Component Id="CompDesktop" Guid="{CDEF1234-0002-4000-9000-AABB00000002}">
        <Shortcut Id="DesktopApp" Name="CyberFence Endpoint"
          Description="CyberFence Endpoint Protection"
          Target="[INSTALLDIR]CyberFence.exe" WorkingDirectory="INSTALLDIR" />
        <RegistryValue Root="HKCU" Key="SOFTWARE\Perez Technology Group\CyberFence Endpoint"
          Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- CyberFence Engine (ClamAV 1.4.4 LTS) -->
